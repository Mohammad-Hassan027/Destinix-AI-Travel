datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum GroupRole {
  OWNER
  EDITOR
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model User {
  id                    String                  @id
  email                 String                  @unique
  name                  String
  avatar                String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  
  ownedGroups           TripGroup[]             @relation("GroupOwner")
  memberships           TripMember[]
  suggestions           DestinationSuggestion[]
  votes                 DestinationVote[]
  messages              DiscussionMessage[]
  expenses              Expense[]
}

model TripGroup {
  id                     String                  @id @default(uuid())
  name                   String
  ownerId                String
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  owner                  User                    @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members                TripMember[]
  itineraries            SharedItinerary[]
  destinationSuggestions DestinationSuggestion[]
  discussions            DiscussionMessage[]
  bookings               SharedBooking[]
  expenses               Expense[]
  invitations            TripInvitation[]
}

model TripMember {
  id          String    @id @default(uuid())
  tripGroupId String
  userId      String
  role        GroupRole @default(VIEWER)

  tripGroup   TripGroup @relation(fields: [tripGroupId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripGroupId, userId])
}

model TripInvitation {
  id          String           @id @default(uuid())
  tripGroupId String
  email       String
  invitedBy   String
  status      InvitationStatus @default(PENDING)

  tripGroup   TripGroup        @relation(fields: [tripGroupId], references: [id], onDelete: Cascade)
  
  @@unique([tripGroupId, email])
}

model SharedItinerary {
  id          String    @id @default(uuid())
  tripGroupId String
  title       String
  description String?
  dayNumber   Int
  createdBy   String
  updatedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tripGroup   TripGroup @relation(fields: [tripGroupId], references: [id], onDelete: Cascade)
}

model DestinationSuggestion {
  id              String            @id @default(uuid())
  tripGroupId     String
  destinationName String
  suggestedBy     String
  createdAt       DateTime          @default(now())

  tripGroup       TripGroup         @relation(fields: [tripGroupId], references: [id], onDelete: Cascade)
  suggestedByUser User              @relation(fields: [suggestedBy], references: [id], onDelete: Cascade)
  votes           DestinationVote[]
}

model DestinationVote {
  id           String                @id @default(uuid())
  suggestionId String
  userId       String

  suggestion   DestinationSuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([suggestionId, userId])
}

model DiscussionMessage {
  id          String    @id @default(uuid())
  tripGroupId String
  userId      String
  message     String
  createdAt   DateTime  @default(now())

  tripGroup   TripGroup @relation(fields: [tripGroupId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SharedBooking {
  id               String    @id @default(uuid())
  tripGroupId      String
  bookingReference String
  bookingType      String
  amount           Float
  status           String
  createdAt        DateTime  @default(now())

  tripGroup        TripGroup @relation(fields: [tripGroupId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String    @id @default(uuid())
  tripGroupId String
  title       String
  amount      Float
  paidBy      String
  createdAt   DateTime  @default(now())

  tripGroup   TripGroup @relation(fields: [tripGroupId], references: [id], onDelete: Cascade)
  payer       User      @relation(fields: [paidBy], references: [id], onDelete: Cascade)
}
